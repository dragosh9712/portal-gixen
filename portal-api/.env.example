# ── Server ────────────────────────────────────────────────────────────────────
PORT=80
NODE_ENV=production
APP_URL=https://portal.gixen.ro

# ── HTTPS (opțional) ──────────────────────────────────────────────────────────
# Generare cert self-signed pe rețea internă:
#   openssl req -x509 -newkey rsa:2048 -keyout key.pem -out cert.pem -days 3650 -nodes -subj "/CN=portal.gixen.ro"
# Dacă setate, serverul pornește pe HTTPS_PORT și PORT redirecționează către HTTPS
SSL_KEY_PATH=
SSL_CERT_PATH=
HTTPS_PORT=443

# ── SQL Server ────────────────────────────────────────────────────────────────
DB_SERVER=localhost
DB_DATABASE=GixenPortal
DB_USER=sa
DB_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ── SMTP (mail.gixen.ro) ─────────────────────────────────────────────────────
SMTP_HOST=mail.gixen.ro
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Logo alb PNG pentru emailuri (dacă lipsește, se afișează text GIXEN)
# Ex: https://portal.gixen.ro/logo-white.png  (pune fișierul în portal-api/dist/)
LOGO_EMAIL_URL=

# ── Curs BNR ──────────────────────────────────────────────────────────────────
# Marja % adăugată peste cursul BNR (default 0.5)
BNR_MARGIN_PCT=0.5

# ── Selectsoft API ────────────────────────────────────────────────────────────
# API-ul rulează local pe serverul Gixen (portul 6081 e blocat din exterior)
SELECTSOFT_URL=http://localhost:6081
SELECTSOFT_TOKEN=
# true → comenzile plasate în portal se trimit automat în Selectsoft (insertcom)
SELECTSOFT_PUSH_ORDERS=false
